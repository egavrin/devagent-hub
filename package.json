{
  "name": "devagent-hub",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egavrin/devagent-hub.git"
  },
  "bugs": {
    "url": "https://github.com/egavrin/devagent-hub/issues"
  },
  "homepage": "https://github.com/egavrin/devagent-hub#readme",
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=20"
  },
  "bin": {
    "devagent-hub": "bin/devagent-hub.js"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "test": "node ./node_modules/vitest/vitest.mjs run --config vitest.config.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx eslint src/",
    "bootstrap:local": "bun run scripts/bootstrap-local.ts",
    "baseline:check": "bun run scripts/baseline/check-baseline.ts",
    "baseline:drift": "bun run scripts/baseline/check-protocol-drift.ts",
    "baseline:compat": "DEVAGENT_HUB_INCLUDE_BASELINE=1 node ./node_modules/vitest/vitest.mjs run --config vitest.config.ts src/__tests__/baseline-compatibility.test.ts",
    "baseline:smoke": "DEVAGENT_HUB_INCLUDE_BASELINE=1 node ./node_modules/vitest/vitest.mjs run --config vitest.config.ts src/__tests__/baseline-machine-path.test.ts",
    "check:oss": "node ./scripts/check-oss.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.0",
    "better-sqlite3": "^11.0.0",
    "bun-types": "latest",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@devagent-runner/core": "file:../devagent-runner/packages/core",
    "@devagent-runner/adapters": "file:../devagent-runner/packages/adapters",
    "@devagent-runner/local-runner": "file:../devagent-runner/packages/local-runner",
    "@devagent-sdk/schema": "file:../devagent-sdk/packages/schema",
    "@devagent-sdk/types": "file:../devagent-sdk/packages/types",
    "@devagent-sdk/validation": "file:../devagent-sdk/packages/validation",
    "yaml": "^2.8.2"
  }
}
