{
  "name": "devagent-hub",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "devagent-hub": "dist/cli/index.js"
  },
  "scripts": {
    "build": "bun build src/cli/index.ts --outdir dist/cli --target bun --external react-devtools-core",
    "test": "node ./node_modules/vitest/vitest.mjs run --config vitest.config.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx eslint src/",
    "baseline:check": "bun run scripts/baseline/check-baseline.ts",
    "baseline:drift": "bun run scripts/baseline/check-protocol-drift.ts",
    "baseline:compat": "node ./node_modules/vitest/vitest.mjs run --config vitest.config.ts src/__tests__/baseline-compatibility.test.ts",
    "baseline:smoke": "node ./node_modules/vitest/vitest.mjs run --config vitest.config.ts src/__tests__/baseline-machine-path.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^19.2.14",
    "better-sqlite3": "^11.0.0",
    "bun-types": "latest",
    "eslint": "^10.0.3",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@devagent-runner/adapters": "file:../devagent-runner/packages/adapters",
    "@devagent-runner/local-runner": "file:../devagent-runner/packages/local-runner",
    "@devagent-sdk/types": "file:../devagent-sdk/packages/types",
    "@devagent-sdk/validation": "file:../devagent-sdk/packages/validation",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "yaml": "^2.8.2"
  }
}
